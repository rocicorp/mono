{
  "name": "zero-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "oxfmt .",
    "check-format": "oxfmt --check .",
    "fmt": "oxfmt .",
    "check-fmt": "oxfmt --check .",
    "lint": "oxlint --quiet --config ../../oxlint.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:chromium": "VITEST_BROWSER=chromium vitest run",
    "test:chromium:watch": "VITEST_BROWSER=chromium vitest",
    "test:firefox": "VITEST_BROWSER=firefox vitest run",
    "test:firefox:watch": "VITEST_BROWSER=firefox vitest",
    "test:webkit": "VITEST_BROWSER=webkit vitest run",
    "test:webkit:watch": "VITEST_BROWSER=webkit vitest",
    "test:update": "vitest run -u",
    "bench": "vitest run --config vitest.config.bench.ts",
    "bench:bmf": "BENCH_OUTPUT_FORMAT=json pnpm run bench 2>&1 | npx tsx ../shared/src/tool/mitata-json-to-bmf.ts",
    "bench:bmf:silent": "pnpm run bench:bmf --silent",
    "check-types": "tsc",
    "check-types:watch": "tsc --watch"
  },
  "dependencies": {
    "@rocicorp/lock": "^1.0.4",
    "@rocicorp/logger": "^5.4.0",
    "@rocicorp/resolver": "^1.0.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.6.0",
    "@standard-schema/spec": "^1.0.0",
    "ast-to-zql": "workspace:*",
    "datadog": "workspace:*",
    "esbuild": "^0.27.4",
    "fast-check": "^3.18.0",
    "oxfmt": "^0.45.0",
    "playwright": "1.58.2",
    "replicache": "workspace:*",
    "shared": "workspace:*",
    "typescript": "~6.0.2",
    "vitest": "^4.1.5",
    "zero-protocol": "workspace:*",
    "zero-schema": "workspace:*",
    "zero-types": "workspace:*",
    "zql": "workspace:*"
  }
}
