{
  "name": "zql-integration-tests",
  "version": "0.0.0",
  "private": true,
  "description": "Integration tests of ZQL, ZQLite, ZPG",
  "type": "module",
  "scripts": {
    "format": "oxfmt .",
    "check-format": "oxfmt --check .",
    "check-types": "tsc",
    "check-types:watch": "tsc --watch",
    "build:bin": "tsc -p tsconfig.bin.json",
    "lint": "oxlint --quiet --config ../../oxlint.config.ts",
    "test": "vitest run",
    "test:pg17": "vitest run --project='*17*'",
    "test:watch": "vitest watch",
    "test:pg17:watch": "vitest watch --project='*17*'",
    "test-types": "vitest run --typecheck.only --no-browser.enabled",
    "test-types:watch": "vitest watch --typecheck.only --no-browser.enabled",
    "fmt": "oxfmt .",
    "check-fmt": "oxfmt --check ."
  },
  "devDependencies": {
    "@faker-js/faker": "^9.6.0",
    "@rocicorp/logger": "^6.1.0",
    "@types/pg": "^8.20.0",
    "@types/tmp": "^0.2.6",
    "ast-to-zql": "workspace:*",
    "otel": "workspace:*",
    "oxfmt": "^0.45.0",
    "pg": "^8.16.3",
    "shared": "workspace:*",
    "typescript": "~6.0.2",
    "vitest": "^4.1.6",
    "z2s": "workspace:*",
    "zero-cache": "workspace:*",
    "zero-protocol": "workspace:*",
    "zero-schema": "workspace:*",
    "zero-server": "workspace:*",
    "zero-types": "workspace:*",
    "zql": "workspace:*",
    "zqlite": "workspace:*"
  },
  "packageManager": "pnpm@11.5.3"
}
