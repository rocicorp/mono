{
  "name": "zero-server",
  "version": "0.0.0",
  "private": true,
  "description": "Library to include in API servers for processing mutation and query requests",
  "type": "module",
  "scripts": {
    "format": "oxfmt .",
    "check-format": "oxfmt --check .",
    "check-types": "tsc",
    "check-types:watch": "tsc --watch",
    "lint": "oxlint --quiet --config ../../oxlint.config.ts src/",
    "postinstall": "prisma generate --schema ./src/adapters/schema.test.prisma",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:pg17": "vitest run --project='*17*'",
    "test:pg17:watch": "vitest watch --project='*17*'",
    "fmt": "oxfmt .",
    "check-fmt": "oxfmt --check ."
  },
  "dependencies": {
    "@rocicorp/logger": "^5.4.0"
  },
  "devDependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@vitest/runner": "^4.1.5",
    "drizzle-orm": "^0.45.2",
    "kysely": "^0.28.17",
    "oxfmt": "^0.45.0",
    "pg": "^8.16.3",
    "postgres": "3.4.7",
    "prisma": "^7.7.0",
    "shared": "0.0.0",
    "vitest": "^4.1.5",
    "z2s": "0.0.0",
    "zero-cache": "0.0.0",
    "zero-protocol": "0.0.0",
    "zero-schema": "0.0.0",
    "zero-types": "0.0.0",
    "zql": "0.0.0"
  }
}
