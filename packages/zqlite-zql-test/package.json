{
  "name": "zqlite-zql-test",
  "version": "0.0.0",
  "private": true,
  "description": "zql tests against zqlite TableSource",
  "type": "module",
  "scripts": {
    "format": "oxfmt .",
    "check-format": "oxfmt --check .",
    "check-types": "tsc",
    "check-types:watch": "tsc --watch",
    "lint": "oxlint --quiet --config ../../oxlint.config.ts src/",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "fmt": "oxfmt .",
    "check-fmt": "oxfmt --check ."
  },
  "dependencies": {
    "zqlite": "workspace:*"
  },
  "devDependencies": {
    "@rocicorp/logger": "^5.4.0",
    "@vitest/runner": "^4.1.5",
    "oxfmt": "^0.45.0",
    "shared": "workspace:*",
    "typescript": "~6.0.2",
    "vitest": "^4.1.5"
  }
}
