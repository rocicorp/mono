    "command-line-args": "^6.0.1",
    "command-line-usage": "^7.0.3",
    "compare-utf8": "^0.2.0",
    "esbuild": "0.27.7",
    "get-port": "^7.0.0",
    "hash-wasm": "^4.9.0",
    "idb": "^7.0.1",
    "playwright": "^1.60.0",
    "playwright-core": "1.53.2",
    "replicache": "workspace:*",
    "shared": "workspace:*",
    "typescript": "~6.0.2",
    "vite": "^8.0.13",
    "xbytes": "^1.7.0"
  },
  "devDependencies": {
    "oxfmt": "^0.45.0"
  },
  "packageManager": "pnpm@11.11.0"
