{
  "name": "replicache-perf",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "oxfmt .",
    "check-format": "oxfmt --check .",
    "check-types": "tsc",
    "check-types:watch": "tsc --watch",
    "lint": "oxlint --quiet --config ../../oxlint.config.ts src/",
    "build": "node tool/build.ts",
