// Dev container profile for local zbugs development/testing.
//
// Same workspace as the default profile, plus the zbugs Postgres services
// (apps/zbugs/docker/docker-compose.yml) started as sibling containers.
// Inside this container there is no need to run `pnpm run db-up` — Postgres
// is already running. The workspace still has no Docker daemon and no host
// Docker socket. See README.md in the parent directory.
{
  "name": "Mono — zbugs (sibling Postgres)",
  "dockerComposeFile": ["../docker-compose.yml", "docker-compose.yml"],
  "service": "dev",
  "workspaceFolder": "/workspaces/mono",
  "shutdownAction": "stopCompose",
  // Vite dev server (5173) and zero-cache (4848). The browser runs on the
  // host and connects to zero-cache via VITE_PUBLIC_SERVER=http://localhost:4848,
  // so 4848 must be forwarded too — not just the page port.
  "forwardPorts": [5173, 4848],
  "remoteUser": "node",
  "features": {
    // Keep in sync with ../devcontainer.json.
    "ghcr.io/rocicorp/devcontainer-features/agents:3": {
      "codexVersion": "0.139.0"
    },
    "ghcr.io/rocicorp/devcontainer-features/pnpm:1": {}
  },
  "postCreateCommand": "pnpm install",
  "customizations": {
    "vscode": {
      "extensions": ["oxc.oxc-vscode@1.57.0"],
      "settings": {
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.formatOnSave": true,
        "extensions.autoUpdate": false,
        "extensions.autoCheckUpdates": false
      }
    }
  }
}
