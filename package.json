{
  "name": "@rocicorp/mono",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "download-deps": "bash ./deps/download.sh",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --quiet --type-aware",
    "fmt": "oxfmt",
    "format": "oxfmt",
    "check-fmt": "oxfmt --check",
    "check-format": "oxfmt --check",
    "check-types": "turbo run check-types",
    "check-types:watch": "turbo watch check-types",
    "start-zero-cache": "cd packages/zero-cache && pnpm run start",
    "verify-deps": "cd tools/verify-package-deps && pnpm run verify",
    "verify-deps:fix": "cd tools/verify-package-deps && pnpm run verify:fix",
    "api-snapshot": "vitest run --config tools/tsnapi/vitest.config.ts",
    "api-snapshot:update": "vitest run -u --config tools/tsnapi/vitest.config.ts",
    "bench": "turbo run bench --concurrency=1",
    "bench:bmf": "turbo run bench:bmf --concurrency=1",
    "bench:bmf:silent": "turbo run bench:bmf:silent --concurrency=1"
  },
  "devDependencies": {
    "@e18e/eslint-plugin": "^0.4.1",
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0",
    "@types/node": "^22.10.5",
    "@vitest/browser": "^4.1.6",
    "@vitest/browser-playwright": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/runner": "^4.1.6",
    "baseline-browser-mapping": "^2.10.16",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "playwright": "^1.60.0",
    "syncpack": "^14.3.0",
    "tsnapi": "^0.3.2",
    "turbo": "^2.4.4",
    "typescript": "~7.0.2",
    "vitest": "^4.1.6",
    "zx": "^8.8.5"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.5.3"
}
