{
  "name": "@rocicorp/mono",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "download-deps": "bash ./deps/download.sh",
    "build": "npx turbo run build",
    "dev": "npx turbo run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --quiet --type-aware",
    "fmt": "oxfmt",
    "format": "oxfmt",
    "check-fmt": "oxfmt --check",
    "check-format": "oxfmt --check",
    "check-types": "npx turbo run check-types",
    "check-types:watch": "npx turbo watch check-types",
    "build-ci": "pnpm install && npx turbo run build",
    "start-zero-cache": "pnpm --filter zero-cache run start",
    "verify-deps": "pnpm --filter verify-package-deps run verify",
    "verify-deps:fix": "pnpm --filter verify-package-deps run verify:fix",
    "api-snapshot": "vitest run --config tools/tsnapi/vitest.config.ts",
    "api-snapshot:update": "vitest run -u --config tools/tsnapi/vitest.config.ts",
    "bench": "npx turbo run bench --concurrency=1",
    "bench:bmf": "npx turbo run bench:bmf --concurrency=1",
    "bench:bmf:silent": "npx turbo run bench:bmf:silent --concurrency=1"
  },
  "devDependencies": {
    "@e18e/eslint-plugin": "^0.4.1",
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0",
    "@types/node": "^22.10.5",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/runner": "^4.1.5",
    "baseline-browser-mapping": "^2.10.16",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "playwright": "^1.53.2",
    "syncpack": "^14.3.0",
    "tsnapi": "^0.3.2",
    "tsx": "^4.21.0",
    "turbo": "^2.4.4",
    "vitest": "^4.1.5",
    "zx": "^8.8.5"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "overrides": {
      "webpackbar": "^7.0.0",
      "playwright": "1.58.2",
      "playwright-core": "1.58.2"
    }
  }
}
