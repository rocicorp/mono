{
  "name": "zbugs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check-types": "tsc -p tsconfig.json && tsc -p tsconfig.node.json",
    "check-types:client:watch": "tsc -p tsconfig.json --watch",
    "check-types:server:watch": "tsc -p tsconfig.node.json --watch",
    "db-up": "cd docker && docker compose up",
    "db-down": "cd docker && docker compose down",
    "db-migrate": "drizzle-kit migrate",
    "db-seed": "node scripts/seed.ts",
    "generate-templates": "node scripts/generate-templates.ts",
    "generate-synthetic": "NODE_OPTIONS='--max-old-space-size=8192' node scripts/generate-synthetic.ts",
    "db-seed-synthetic": "ZERO_SEED_DATA_DIR=db/seed-data/synthetic node scripts/seed.ts",
    "clean": "cd docker && docker compose down && docker volume rm docker_zbugs_pgdata_sync && docker volume rm docker_zbugs_pgdata_upstream && rm -rf /tmp/zbugs-sync-replica.db*",
    "format": "oxfmt --config ../../.oxfmtrc.json .",
    "check-format": "oxfmt --config ../../.oxfmtrc.json --check .",
    "lint": "oxlint --quiet --config ../../oxlint.config.ts src/",
    "preview": "vite preview",
    "zero": "node --trace-warnings ../../packages/zero-cache/src/server/runner/main.ts",
    "zero-cache-dev": "node ../../packages/zero/src/zero-cache-dev.ts",
    "zero-brk": "node --inspect-brk ../../packages/zero-cache/src/server/debug/single.ts",
    "transform-query": "node ../../packages/zero-cache/src/scripts/transform-query.ts",
    "run-query": "node ../../packages/zero-cache/src/scripts/run-query.ts",
    "run-query-brk": "node --inspect-brk ../../packages/zero-cache/src/scripts/run-query.ts",
    "create-keys": "node ../../packages/zero-cache/src/scripts/create-jwk.ts",
    "analyze-query": "node scripts/analyze.ts",
    "test": "cd ../../packages/zero && pnpm run build && cd ../../apps/zbugs && vitest run --config vitest.config.ts --project zbugs/no-pg",
    "test:watch": "vitest --config vitest.config.ts --project zbugs/no-pg",
    "analyze": "analyze -c vite.config.ts",
    "test:pg": "vitest run --config vitest.config.ts --project zbugs/pg-16",
    "test:pg:watch": "vitest --config vitest.config.ts --project zbugs/pg-16",
    "fmt": "oxfmt .",
    "check-fmt": "oxfmt --check ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.844.0",
    "@aws-sdk/s3-request-presigner": "^3.844.0",
    "@dotenvx/dotenvx": "^1.39.0",
    "@faker-js/faker": "^9.6.0",
    "@fastify/cookie": "^10.0.0",
    "@fastify/oauth2": "^8.0.0",
    "@floating-ui/react": "^0.26.28",
    "@headlessui/react": "^2.1.8",
    "@octokit/core": "^6.1.2",
    "@rocicorp/zero": "workspace:*",
    "@rocicorp/zero-virtual": "^0.1.1",
    "@schickling/fps-meter": "^0.1.2",
    "@tanstack/react-virtual": "^3.13.19",
    "classnames": "^2.5.1",
    "emoji-picker-element": "^1.22.8",
    "emoji-picker-element-data": "^1.6.1",
    "fastify": "^5.0.0",
    "jose": "^5.9.3",
    "js-cookie": "^3.0.5",
    "nanoid": "^5.1.2",
    "pg": "^8.16.3",
    "postgres": "3.4.7",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-dropzone": "^14.3.8",
    "react-markdown": "^9.0.1",
    "react-textarea-autosize": "^8.5.3",
    "react-toastify": "^10.0.6",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "use-debounce": "^10.0.4",
    "usehooks-ts": "^3.1.0",
    "wouter": "^3.7.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.0",
    "@types/hast": "^3.0.4",
    "@types/js-cookie": "^3.0.6",
    "@types/k6": "^0.53.2",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/runner": "^4.1.6",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "oxfmt": "^0.45.0",
    "postcss-preset-env": "^7.4.3",
    "rehype-video": "^2.3.0",
    "shared": "workspace:*",
    "tailwindcss": "^3.0.23",
    "typescript": "~6.0.2",
    "vite": "^8.0.13",
    "vite-bundle-analyzer": "^1.3.8",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@11.3.0"
}
