#### zero.config.js Variables ####

# The "upstream" authoritative postgres database
# In the future we will support other types of upstreams besides PG
ZERO_UPSTREAM_DB = "postgresql://user:password@127.0.0.1:6434/postgres"

# Where to send custom mutations
ZERO_MUTATE_URL = "http://localhost:5173/api/mutate"
ZERO_QUERY_URL = "http://localhost:5173/api/query"

ZERO_LOG_LEVEL = "info"

# Use "json" for logs consumed by structured logging services.
ZERO_LOG_FORMAT = "text"

#### ZBugs API Server Variables ####

# The client id for the GitHub OAuth app responisble for OAuth:
# https://docs.github.com/en/apps/creating-github-apps
# Rocicorp team, see:
# https://docs.google.com/document/d/1aGHaB0L15SY67wkXQMsST80uHh4-IooTUVzKcUlzjdk/edit#bookmark=id.bb6lqbetv2lm
GITHUB_CLIENT_ID = ""
# The secret for the client
GITHUB_CLIENT_SECRET = ""
# You can create a JWK pair via `npm run create-keys`
# in the `zbugs` directory.
#
# The private key goes here
# The public key goes in `VITE_PUBLIC_JWK`.
PRIVATE_JWK = ""

#### Vite Variables ####
VITE_PUBLIC_SERVER="http://localhost:4848"
# See comment on `ZERO_AUTH_JWK`
VITE_PUBLIC_JWK=''

# Discord webhook to send notifications to. Not required. Notifications won't
# be sent if absent.
DISCORD_WEBHOOK_URL=''

# AWS credentials for image uploads. Required for image upload functionality.
AWS_REGION=''
AWS_ACCESS_KEY_ID=''
AWS_SECRET_ACCESS_KEY=''

#### Static-replica debug mode ####
#
# Run zero-cache against an existing SQLite replica file with NO upstream
# Postgres connection. Useful for debugging issues against a pre-built
# replica (e.g. a captured production-shaped replica).
#
# To use it, leave ZERO_UPSTREAM_DB unset and set:
#
#   ZERO_UPSTREAM_TYPE=static
#   ZERO_REPLICA_FILE=/absolute/path/to/your.db
#   ZERO_CVR_DB=postgresql://user:password@127.0.0.1:6435/postgres
#   ZERO_CHANGE_DB=postgresql://user:password@127.0.0.1:6435/postgres
#
# Notes:
# - The replica file is opened read-only; zero-cache will not mutate it.
# - No initial sync, no replication slot, no upstream connection is made.
# - CRUD mutations are forced off (the shadow-sync canary is also skipped).
# - A local Postgres is still required for CVR_DB and CHANGE_DB; the
#   existing zbugs docker-compose `db-up` Postgres on :6435 works.
