{
  "name": "otel-proxy",
  "version": "1.0.0",
  "description": "OTEL metrics proxy for Grafana",
  "main": "api/index.ts",
  "scripts": {
    "dev": "vercel dev",
    "deploy": "vercel deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --quiet --config ../../oxlint.config.ts .",
    "format": "oxfmt .",
