    "check-types": "tsc --noEmit",
    "fmt": "oxfmt .",
    "check-fmt": "oxfmt --check ."
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^4.1.6",
    "oxfmt": "^0.45.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@11.3.0"
}
